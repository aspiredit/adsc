# Cloudflare credentials for the chat embedding build (slice A2).
#
# Copy this file to `.env` and fill in the real values. `.env` is gitignored,
# so the token never gets committed. build_embeddings.py auto-loads `.env` from
# the repo root when present.
#
# The token needs ONLY the "Workers AI → Read" permission, scoped to your
# account. Create it at: dash.cloudflare.com → My Profile → API Tokens →
# Create Custom Token. Revoke it after the embeddings are built if you like —
# it's only needed again when site content changes.

CLOUDFLARE_ACCOUNT_ID=5d934a64cd8e6bd0823822134432b711
CLOUDFLARE_API_TOKEN=your-workers-ai-token-here
